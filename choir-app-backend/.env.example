# =============================================================================
# Chorleiter Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your specific values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=8088
ADDRESS=localhost
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL or SQLite)
# -----------------------------------------------------------------------------
# For PostgreSQL (production):
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chorleiter
DB_USER=chorleiter_user
DB_PASSWORD=your_secure_password_here

# For SQLite (local development/testing):
# DB_DIALECT=sqlite
# DB_NAME=./database.sqlite

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# CRITICAL: Use a strong, random secret in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_in_production

# -----------------------------------------------------------------------------
# Email Configuration (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=no-reply@nak-chorleiter.de

# -----------------------------------------------------------------------------
# System Configuration
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
SYSTEM_ADMIN_EMAIL=admin@example.com
FRONTEND_URL=http://localhost:4200

# -----------------------------------------------------------------------------
# Push Notifications (PWA - optional)
# -----------------------------------------------------------------------------
# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your_email@example.com
PUSH_MAX_SUBSCRIPTIONS_PER_USER=10

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# Debug Flags (development only)
# -----------------------------------------------------------------------------
DEBUG_AUTH=false
DEBUG_CSRF=false

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=Europe/Berlin
